graph TB
    subgraph "OpenShift Cluster (build10.ci.devcluster.openshift.com)"
        subgraph "Namespace: winc-dashboard (Production)"
            ProdSecrets[("Secrets<br/>reportportal-secret<br/>dashboard-secrets")]
            ProdBuild[BuildConfig<br/>winc-dashboard<br/>Source: Git<br/>Strategy: Docker]
            ProdImage[ImageStream<br/>winc-dashboard:latest]
            ProdDeploy[Deployment<br/>Replicas: 1<br/>Container: dashboard<br/>Port: 5000]
            ProdPod[Pod<br/>Status: Running]
            ProdService[Service<br/>ClusterIP<br/>Port: 5000]
            ProdRoute[Route<br/>TLS: Edge<br/>Host: winc-dashboard-<br/>winc-dashboard.apps...]
            ProdPVC[PVC<br/>dashboard-data<br/>10Gi<br/>/data/dashboard.db]

            ProdBuild --> ProdImage
            ProdImage --> ProdDeploy
            ProdDeploy --> ProdPod
            ProdPod --> ProdService
            ProdService --> ProdRoute
            ProdPod -.Mount.- ProdPVC
            ProdSecrets -.Env.- ProdPod
        end

        subgraph "Namespace: winc-dashboard-poc (POC + AI + Jira)"
            POCSecrets[("Secrets<br/>dashboard-secrets<br/>JIRA_API_TOKEN<br/>ANTHROPIC_VERTEX")]
            POCConfig[ConfigMap<br/>dashboard-config<br/>job_patterns]
            POCBuild[BuildConfig<br/>winc-dashboard-poc<br/>Source: Git<br/>Strategy: Docker]
            POCImage[ImageStream<br/>winc-dashboard-poc<br/>Build: 85]
            POCDeploy[Deployment<br/>Replicas: 1<br/>Container: dashboard<br/>Port: 5000]
            POCPod[Pod<br/>Status: Running<br/>AI + Jira Enabled]
            POCService[Service<br/>ClusterIP<br/>Port: 5000]
            POCRoute[Route<br/>TLS: Edge<br/>Host: winc-dashboard-poc...]
            POCPVC[PVC<br/>dashboard-data<br/>10Gi<br/>/data/dashboard.db]

            POCBuild --> POCImage
            POCImage --> POCDeploy
            POCDeploy --> POCPod
            POCPod --> POCService
            POCService --> POCRoute
            POCPod -.Mount.- POCPVC
            POCSecrets -.Env.- POCPod
            POCConfig -.Config.- POCPod
        end
    end

    subgraph "External Services"
        GitHub[GitHub Repository<br/>ci-failure-tracker<br/>Branch: master]
        ReportPortal[ReportPortal API<br/>Test Results]
        ProwGCS[Prow GCS<br/>JUnit XML Files<br/>gcsweb-qe-private-deck]
        VertexAI[Google Vertex AI<br/>Claude Sonnet 4<br/>Region: us-east5]
        Jira[Jira API<br/>issues.redhat.com<br/>Project: WINC]
    end

    subgraph "CI Pipeline"
        CIJobs[CI Jobs<br/>Periodic<br/>Rehearse<br/>Pull-CI]
        CIJobs --> ReportPortal
        CIJobs --> ProwGCS
    end

    GitHub -->|Webhook<br/>Push Event| ProdBuild
    GitHub -->|Webhook<br/>Push Event| POCBuild

    ReportPortal -->|Collect Data| ProdPod
    ProwGCS -->|Collect Data| POCPod

    POCPod -->|AI Analysis| VertexAI
    POCPod -->|Create Tickets| Jira

    ProdRoute -->|HTTPS| Users[Users/Browsers]
    POCRoute -->|HTTPS| Users

    style ProdSecrets fill:#ff9999
    style POCSecrets fill:#ff9999
    style ProdPVC fill:#99ccff
    style POCPVC fill:#99ccff
    style GitHub fill:#ffcc99
    style ReportPortal fill:#ccffcc
    style ProwGCS fill:#ccffcc
    style VertexAI fill:#ffccff
    style Jira fill:#ffccff
