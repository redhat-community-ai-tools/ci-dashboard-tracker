graph TB
    subgraph "OpenShift Cluster (build10.ci.devcluster.openshift.com)"
        subgraph "Namespace: winc-dashboard-poc"
            Secrets[("Secrets<br/>dashboard-secrets<br/>JIRA_API_TOKEN<br/>JIRA_EMAIL<br/>ANTHROPIC_VERTEX_PROJECT_ID<br/>ANTHROPIC_VERTEX_REGION")]
            Config[ConfigMap<br/>dashboard-config<br/>job_patterns]

            Build[BuildConfig<br/>winc-dashboard-poc<br/>Source: Git<br/>Strategy: Docker]
            Image[ImageStream<br/>winc-dashboard-poc<br/>Latest: Build 85]

            Deploy[Deployment<br/>winc-dashboard-poc<br/>Replicas: 1<br/>Container: dashboard<br/>Port: 5000]
            Pod[Pod<br/>dashboard<br/>Status: Running<br/>AI + Jira Enabled]

            CronJob[CronJob<br/>dashboard-collector<br/>Schedule: Every 6 hours<br/>Triggers data collection]
            CronPod[Job Pods<br/>Collect from Prow GCS<br/>Parse JUnit XML<br/>Store in database]

            Service[Service<br/>winc-dashboard-poc<br/>ClusterIP<br/>Port: 5000]
            Route[Route<br/>TLS: Edge<br/>Host: winc-dashboard-poc-<br/>winc-dashboard-poc...]

            PVC[PVC<br/>dashboard-data<br/>10Gi RWO<br/>/data/dashboard.db]

            Build --> Image
            Image --> Deploy
            Deploy --> Pod
            Pod --> Service
            Service --> Route
            Pod -.Mount.- PVC
            CronJob -.Creates.- CronPod
            CronPod -.Mount.- PVC
            Secrets -.Env.- Pod
            Secrets -.Env.- CronPod
            Config -.Config.- Pod
            Config -.Config.- CronPod
        end
    end

    subgraph "External Services"
        GitHub[GitHub Repository<br/>ci-dashboard-tracker<br/>Branch: master]
        ProwGCS[Prow GCS<br/>JUnit XML Files<br/>gcsweb-qe-private-deck-ci]
        VertexAI[Google Vertex AI<br/>Claude Sonnet 4<br/>Region: us-east5]
        Jira[Jira API<br/>issues.redhat.com<br/>Project: WINC]
    end

    subgraph "CI Pipeline"
        CIJobs[CI Jobs<br/>Periodic<br/>Rehearse<br/>Pull-CI]
        CIJobs --> ProwGCS
    end

    GitHub -->|Webhook<br/>Push Event| Build

    ProwGCS -->|Scheduled Collection| CronPod
    ProwGCS -->|Manual Collection| Pod

    Pod -->|AI Analysis| VertexAI
    Pod -->|Create Tickets| Jira

    Route -->|HTTPS| Users[Users/Browsers]

